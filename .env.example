# Environment Variables Template
# Copy this to .env and fill in your actual values
# WARNING: Never commit .env file to GitHub (add to .gitignore)

# ====================
# GEMINI AI CHATBOT
# ====================
# Get API key from Google AI Studio:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY= AIzaSyDIFazT83lfl_MrRNvlojzJIisJFa-oXUA

# Optional fallback key (if you want secondary provider support)
# MISTRAL_API_KEY=

# Optional: choose Gemini model
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Choose specific Mistral model
# Options: mistral-small-latest, mistral-medium-latest, mistral-large-latest
# Default is mistral-small-latest (fastest and cheapest)
# MISTRAL_MODEL=mistral-small-latest

# ====================
# DATABASE CONFIGURATION
# ====================
# For SQLite (local development): sqlite:///tpc_portal.db
# For PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL=

# ====================
# FLASK CONFIGURATION
# ====================
FLASK_ENV=development
SECRET_KEY=your-very-secret-key-change-this-in-production

# ====================
# FILE UPLOAD CONFIGURATION
# ====================
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes

# ====================
# DEBUG SETTINGS
# ====================
DEBUG=True

# Optional: override Gemini API base URL
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
